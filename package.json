{
  "name": "spotify-api-client",
  "version": "1.0.0",
  "description": "TypeScript client for Spotify Web API",
  "main": "dist/index.js",
  "scripts": {
    "build": "next build",
    "build:lib": "tsc -p tsconfig.json",
    "dev": "next dev",
    "web:dev": "next dev",
    "web:build": "next build",
    "web:start": "next start",
    "test": "ts-node test.ts",
