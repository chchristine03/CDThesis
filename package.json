    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/p5": "^1.7.6",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
